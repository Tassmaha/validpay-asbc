# ─────────────────────────────────────────────────────────────
# Template des secrets — NE PAS COMMITER de valeurs réelles.
# Copier ce fichier vers .streamlit/secrets.toml pour usage local.
# Sur Streamlit Community Cloud : coller le contenu ci-dessous
# dans le panneau "Secrets" de l'application.
# ─────────────────────────────────────────────────────────────

# Clé API Google Gemini (optionnelle — l'Assistant local fonctionne sans).
# Obtenir une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY = "your-gemini-api-key-here"
